{
  "name": "immich-wallpaper",
  "version": "0.1.1",
  "description": "macOS menu bar app that drives your desktop wallpaper from an Immich instance",
  "main": "./out/main/index.js",
  "author": "Dennis Mayk <https://github.com/dm807cam>",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "menubar": "^9.5.2",
    "sharp": "^0.33.5",
    "wallpaper": "^7.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "electron": "^39.8.5",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.1.9"
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "esbuild@0.21.5": true,
    "sharp@0.33.5": true
  }
}
